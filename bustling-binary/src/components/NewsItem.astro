---
import type { NewsItem } from "../data/news";

interface Props {
    item: NewsItem;
}

const { item } = Astro.props;
const hasImages = item.images && item.images.length > 0;
const hasLinks = item.links && item.links.length > 0;
const hasVideos = item.videos && item.videos.length > 0;
---

<article class="news-item" id={item.id}>
    <div class="news-item__meta">
        <time>{item.date}</time>
    </div>

    <div class="news-item__body">
        <h3 class="news-item__headline">{item.headline}</h3>
        <p class="news-item__text">{item.body}</p>

        {
            hasImages && (
                <div
                    class:list={[
                        "news-item__gallery",
                        `news-item__gallery--${Math.min(item.images!.length, 4)}`,
                    ]}
                >
                    {item.images!.map((img, i) => (
                        <button
                            class="news-item__thumb"
                            data-lightbox-group={item.id}
                            data-lightbox-index={i}
                            data-src={img.src}
                            data-alt={img.alt}
                            aria-label={`View ${img.alt}`}
                        >
                            <img src={img.src} alt={img.alt} loading="lazy" />
                            <span class="news-item__zoom">⤢</span>
                        </button>
                    ))}
                </div>
            )
        }

        {
            hasLinks && (
                <details class="news-item__links">
                    <summary>Presented Papers & Links</summary>
                    <ul>
                        {item.links!.map((link) => (
                            <li>
                                {link.href ? (
                                    <a
                                        href={link.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                    >
                                        {link.title}
                                    </a>
                                ) : (
                                    <span class="news-item__paper">
                                        {link.title}
                                    </span>
                                )}
                            </li>
                        ))}
                    </ul>
                </details>
            )
        }

        {
            hasVideos && (
                <div class="news-item__videos">
                    {item.videos!.map((v) => (
                        <div class="news-item__video-wrap">
                            <p class="news-item__video-title">{v.title}</p>
                            <iframe
                                src={v.src}
                                title={v.title}
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                                loading="lazy"
                            />
                        </div>
                    ))}
                </div>
            )
        }
    </div>
</article>

<style>
    .news-item {
        display: grid;
        grid-template-columns: 100px 1fr;
        gap: 1.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--color-border);
    }

    .news-item:last-child {
        border: none;
        padding-bottom: 0;
    }

    .news-item__meta time {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--color-accent);
        padding-top: 0.25rem;
        display: block;
    }

    .news-item__headline {
        font-family: var(--font-display);
        font-size: 1.1rem;
        color: var(--color-navy);
        margin-bottom: 0.4rem;
    }

    .news-item__text {
        font-size: 0.875rem;
        color: var(--color-muted);
        line-height: 1.7;
        margin-bottom: 1rem;
    }

    /* Photo grid */
    .news-item__gallery {
        display: grid;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .news-item__gallery--1 {
        grid-template-columns: 1fr;
        max-width: 400px;
    }
    .news-item__gallery--2 {
        grid-template-columns: repeat(2, 1fr);
    }
    .news-item__gallery--3 {
        grid-template-columns: repeat(3, 1fr);
    }
    .news-item__gallery--4 {
        grid-template-columns: repeat(2, 1fr);
    }

    .news-item__thumb {
        position: relative;
        border: none;
        padding: 0;
        cursor: zoom-in;
        border-radius: 6px;
        overflow: hidden;
        background: var(--color-border);
        aspect-ratio: 4/3;
    }

    .news-item__thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition:
            transform 0.3s ease,
            filter 0.3s ease;
        display: block;
    }

    .news-item__thumb:hover img {
        transform: scale(1.05);
        filter: brightness(0.85);
    }

    .news-item__zoom {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 1.5rem;
        color: white;
        opacity: 0;
        transition: opacity 0.2s ease;
        pointer-events: none;
    }

    .news-item__thumb:hover .news-item__zoom {
        opacity: 1;
    }

    /* Papers dropdown */
    .news-item__links {
        margin-bottom: 0.75rem;
    }

    .news-item__links summary {
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--color-link);
        list-style: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        user-select: none;
    }

    .news-item__links summary::-webkit-details-marker {
        display: none;
    }
    .news-item__links summary::before {
        content: "›";
        transition: transform 0.2s;
        display: inline-block;
    }
    .news-item__links[open] summary::before {
        transform: rotate(90deg);
    }

    .news-item__links ul {
        margin: 0.5rem 0 0 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .news-item__links a {
        display: block;
        font-size: 0.8rem;
        padding: 0.4rem 0.7rem;
        border: 1px solid var(--color-link);
        border-radius: 4px;
        color: var(--color-link);
        text-decoration: none;
        transition:
            background 0.15s,
            color 0.15s;
    }

    .news-item__links a:hover {
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: white;
    }

    /* Videos */
    .news-item__videos {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .news-item__video-title {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--color-muted);
        margin-bottom: 0.4rem;
    }

    .news-item__video-wrap iframe {
        width: 100%;
        aspect-ratio: 16/9;
        border-radius: 6px;
        border: none;
    }

    @media (max-width: 600px) {
        .news-item {
            grid-template-columns: 1fr;
            gap: 0.5rem;
        }
        .news-item__gallery--3 {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
