---
import type { Person } from "../data/people";

interface Props {
  person: Person;
  size?: "faculty" | "regular";
}

const { person, size = "regular" } = Astro.props;
const isFaculty = size === "faculty";
---

<div class:list={["person-card", { "person-card--faculty": isFaculty }]}>
  <div class="person-card__photo-wrap">
    <img
      src={person.photo}
      alt={person.name}
      class="person-card__photo"
      loading="lazy"
      onerror="this.src='/Media_1/portraits/placeholder.jpg'"
    />
  </div>

  <div class="person-card__body">
    <h3 class="person-card__name">{person.name}</h3>

    {person.role && (
      <span class="person-card__role">{person.role}</span>
    )}

    {person.researchInterests && (
      <p class="person-card__interests">{person.researchInterests}</p>
    )}

    <div class="person-card__links">
      {person.linkedin && (
        <a href={person.linkedin} class="person-card__icon-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19M18.5 18.5V13.2A3.26 3.26 0 0 0 15.24 9.94C14.39 9.94 13.4 10.46 12.92 11.24V10.13H10.13V18.5H12.92V13.57C12.92 12.8 13.54 12.17 14.31 12.17A1.4 1.4 0 0 1 15.71 13.57V18.5H18.5M6.88 8.56A1.68 1.68 0 0 0 8.56 6.88C8.56 5.95 7.81 5.19 6.88 5.19A1.69 1.69 0 0 0 5.19 6.88C5.19 7.81 5.95 8.56 6.88 8.56M8.27 18.5V10.13H5.5V18.5H8.27Z"/></svg>
        </a>
      )}
      {person.email && (
        <a href={`mailto:${person.email}`} class="person-card__icon-link" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
      )}
      {person.website && (
        <a href={person.website} class="person-card__icon-link" target="_blank" rel="noopener noreferrer" aria-label="Website">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M16.36 14c.08-.34.14-.7.14-1.07 0-.36-.06-.71-.14-1.05l2.26-1.76c.2-.16.26-.44.13-.67l-2.14-3.71c-.13-.24-.41-.31-.64-.24l-2.66 1.07c-.56-.43-1.18-.79-1.86-1.05L11.05 2.7c-.04-.27-.27-.47-.54-.47H6.49c-.27 0-.5.2-.54.47l-.41 2.52c-.68.26-1.3.62-1.86 1.05L1.02 5.2c-.23-.07-.51 0-.64.24L.02 9.15c-.13.24-.07.52.13.67L2.41 11.58c-.08.34-.14.69-.14 1.05 0 .36.06.72.14 1.07L.15 15.46c-.2.16-.26.44-.13.67l2.14 3.71c.13.24.41.31.64.24l2.66-1.07c.56.43 1.18.79 1.86 1.05l.41 2.52c.04.27.27.47.54.47h4.28c.27 0 .5-.2.54-.47l.41-2.52c.68-.26 1.3-.62 1.86-1.05l2.66 1.07c.23.07.51 0 .64-.24l2.14-3.71c.13-.24.07-.52-.13-.67l-2.27-1.76zM9 14c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z"/></svg>
        </a>
      )}
    </div>

    {person.projects && person.projects.length > 0 && (
      <details class="person-card__projects">
        <summary class="person-card__projects-toggle">
          Projects <span class="toggle-icon">›</span>
        </summary>
        <ul class="person-card__project-list">
          {person.projects.map((p) => (
            <li>
              <a href={p.href} target="_blank" rel="noopener noreferrer">
                {p.title}
              </a>
            </li>
          ))}
        </ul>
      </details>
    )}
  </div>
</div>

<style>
  .person-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: box-shadow 0.2s ease;
  }

  .person-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .person-card__photo-wrap {
    flex-shrink: 0;
  }

  .person-card__photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border);
  }

  .person-card--faculty .person-card__photo {
    width: 108px;
    height: 108px;
  }

  .person-card__body {
    flex: 1;
    min-width: 0;
  }

  .person-card__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.15rem;
    line-height: 1.3;
  }

  .person-card--faculty .person-card__name {
    font-size: 1.2rem;
  }

  .person-card__role {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .person-card__interests {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0.25rem 0 0.6rem;
  }

  .person-card__links {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .person-card__icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .person-card__icon-link:hover {
    background: var(--color-accent-dark);
  }

  /* Projects accordion */
  .person-card__projects {
    margin-top: 0.4rem;
  }

  .person-card__projects-toggle {
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-link);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    user-select: none;
  }

  .person-card__projects-toggle::-webkit-details-marker {
    display: none;
  }

  .toggle-icon {
    transition: transform 0.2s ease;
    display: inline-block;
  }

  details[open] .toggle-icon {
    transform: rotate(90deg);
  }

  .person-card__project-list {
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .person-card__project-list a {
    display: block;
    font-size: 0.78rem;
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--color-link);
    border-radius: 4px;
    color: var(--color-link);
    text-decoration: none;
    line-height: 1.35;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .person-card__project-list a:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .person-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .person-card__links {
      justify-content: center;
    }

    .person-card__projects-toggle {
      justify-content: center;
    }
  }
</style>
