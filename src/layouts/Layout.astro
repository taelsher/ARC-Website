---
import "../styles/global.css";
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "MINES ARC Research Group",
  description = "Antennas, RFID, and Computational Electromagnetics at Colorado School of Mines",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Serif+Display&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- Header --> <header class="site-header">
      <div class="nav-top container">
        <a href="#home" class="nav__logo">
          <img
            src="/Media_1/arcLogo_header.png"
            alt="ARC Research Group"
            class="nav__logo-img"
          />
        </a>
        <a
          href="https://electrical.mines.edu/"
          target="_blank"
          rel="noopener noreferrer"
          class="nav__ee-logo"
        >
          <img src="/Media_1/ee_logo.webp" alt="EE Department" />
        </a>
      </div>
      <nav class="nav-bottom">
        <div class="container nav-bottom__inner">
          <ul class="nav__links" id="navLinks">
            <li><a href="#home">Home</a></li>
            <li><a href="#research">Research</a></li>
            <li><a href="#team">Team</a></li>
            <li><a href="#scholarship">Scholarship</a></li>
            <li><a href="#news">News</a></li>
            <li><a href="#software">Software</a></li>
            <li><a href="#contact">Contact</a></li>
          </ul>
          <button class="nav__toggle" aria-label="Toggle menu" id="navToggle">
            <span></span><span></span><span></span>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          ARC Research Group &mdash; Colorado School of Mines, Brown Hall,
          Golden, CO 80401
        </p>
        <p>Powered by Mines Graduate Students</p>
      </div>
    </footer>

    <script>
      // Mobile nav toggle
      const toggle = document.getElementById("navToggle");
      const links = document.getElementById("navLinks");
      toggle?.addEventListener("click", () => {
        links?.classList.toggle("nav__links--open");
        toggle.classList.toggle("nav__toggle--open");
      });
      // Close on link click
      links?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          links.classList.remove("nav__links--open");
          toggle?.classList.remove("nav__toggle--open");
        }),
      );
    </script>
    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true">
      <button class="lightbox__close" id="lightboxClose" aria-label="Close"
        >×</button
      >
      <button
        class="lightbox__nav lightbox__nav--prev"
        id="lightboxPrev"
        aria-label="Previous">‹</button
      >
      <img class="lightbox__img" id="lightboxImg" src="" alt="" />
      <p class="lightbox__caption" id="lightboxCaption"></p>
      <button
        class="lightbox__nav lightbox__nav--next"
        id="lightboxNext"
        aria-label="Next">›</button
      >
    </div>

    <script>
      // Lightbox
      const lightbox = document.getElementById("lightbox")!;
      const lbImg = document.getElementById("lightboxImg") as HTMLImageElement;
      const lbCaption = document.getElementById("lightboxCaption")!;
      const lbClose = document.getElementById("lightboxClose")!;
      const lbPrev = document.getElementById("lightboxPrev")!;
      const lbNext = document.getElementById("lightboxNext")!;

      let currentGroup: HTMLElement[] = [];
      let currentIndex = 0;

      function openLightbox(buttons: HTMLElement[], index: number) {
        currentGroup = buttons;
        currentIndex = index;
        showSlide(index);
        lightbox.classList.add("open");
        document.body.style.overflow = "hidden";
      }

      function showSlide(index: number) {
        const btn = currentGroup[index];
        lbImg.src = btn.dataset.src!;
        lbImg.alt = btn.dataset.alt!;
        lbCaption.textContent = btn.dataset.alt!;
        lbPrev.style.display = currentGroup.length > 1 ? "" : "none";
        lbNext.style.display = currentGroup.length > 1 ? "" : "none";
      }

      function closeLightbox() {
        lightbox.classList.remove("open");
        document.body.style.overflow = "";
      }

      lbClose.addEventListener("click", closeLightbox);
      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      lbPrev.addEventListener("click", () => {
        currentIndex =
          (currentIndex - 1 + currentGroup.length) % currentGroup.length;
        showSlide(currentIndex);
      });

      lbNext.addEventListener("click", () => {
        currentIndex = (currentIndex + 1) % currentGroup.length;
        showSlide(currentIndex);
      });

      document.addEventListener("keydown", (e) => {
        if (!lightbox.classList.contains("open")) return;
        if (e.key === "Escape") closeLightbox();
        if (e.key === "ArrowLeft") lbPrev.click();
        if (e.key === "ArrowRight") lbNext.click();
      });

      // Wire up all thumb buttons
      document
        .querySelectorAll<HTMLElement>("[data-lightbox-group]")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            const group = btn.dataset.lightboxGroup!;
            const buttons = Array.from(
              document.querySelectorAll<HTMLElement>(
                `[data-lightbox-group="${group}"]`,
              ),
            );
            openLightbox(buttons, parseInt(btn.dataset.lightboxIndex!));
          });
        });
    </script>
  </body>
</html>
