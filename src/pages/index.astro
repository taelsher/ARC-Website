---
import Layout from "../layouts/Layout.astro";
import PeopleSection from "../components/PeopleSection.astro";
import { getPeople } from "../data/people";

const faculty     = getPeople("faculty");
const phd         = getPeople("phd");
const ms          = getPeople("ms");
const undergrad   = getPeople("undergrad");
const pastFaculty = getPeople("past-faculty");
const pastPhd     = getPeople("past-phd");
const pastMs      = getPeople("past-ms");
const pastUnder   = getPeople("past-undergrad");

import NewsItemComponent from "../components/NewsItem.astro";
import { newsItems, newsYears, getNewsByYear } from "../data/news";

const currentYear = newsYears[0];
const currentYearItems = getNewsByYear(currentYear);
const archiveYears = newsYears.slice(1);
---

<Layout>
  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="hero" id="home">
    <div class="hero__overlay"></div>
    <div class="container hero__inner">
      <span class="section-eyebrow">Colorado School of Mines</span>
      <h1 class="hero__title">Antennas, RFID &amp;<br />Computational EM</h1>
      <p class="hero__sub">
        The ARC Research Group advances high-frequency antenna design, RFID localization,
        and FDTD-based electromagnetic simulation at the frontier of wireless technology.
      </p>
      <div class="hero__cta">
        <a href="#team" class="btn btn--primary">Meet the Team</a>
        <a href="#research" class="btn btn--outline-white">Our Research</a>
      </div>
    </div>
    <div class="hero__stats">
      <div class="stat"><span class="stat__num">19+</span><span class="stat__label">Members</span></div>
      <div class="stat"><span class="stat__num">55+</span><span class="stat__label">Projects</span></div>
      <div class="stat"><span class="stat__num">50+</span><span class="stat__label">Publications</span></div>
      <div class="stat"><span class="stat__num">150+</span><span class="stat__label">Meetings</span></div>
    </div>
  </section>

  <!-- ── RESEARCH AREAS ────────────────────────────────────────────── -->
  <section class="section section--light" id="research">
    <div class="container">
      <span class="section-eyebrow">What We Do</span>
      <h2 class="section-title">Research Areas</h2>
      <div class="research-grid">
        <div class="research-card">
          <div class="research-card__icon">📡</div>
          <h3>Antenna Design</h3>
          <p>Full-spectrum antenna development from simulation (HFSS, CEMS) through in-house fabrication to anechoic chamber measurement. Miniaturized, wideband, and conformal designs for CubeSats to 5G.</p>
        </div>
        <div class="research-card">
          <div class="research-card__icon">🏷️</div>
          <h3>RFID Systems</h3>
          <p>Novel miniaturized reader/tag antenna designs and new RFID applications, with a focus on cost-effective passive RFID localization for challenging environments including underground mines.</p>
        </div>
        <div class="research-card">
          <div class="research-card__icon">💻</div>
          <h3>Computational EM</h3>
          <p>FDTD-based solvers accelerated with multi-GPU/CPU consumer hardware (Nvidia RTX/Titan, Intel i7). Applications span antenna characterization, biomedical imaging, and drilling-environment propagation.</p>
        </div>
        <div class="research-card">
          <div class="research-card__icon">🎓</div>
          <h3>EM Education</h3>
          <p>Interactive visualization tools, guided simulation software, and hands-on measurement demonstrations to make electromagnetic phenomena accessible to students at all levels.</p>
        </div>
      </div>

      <!-- Lab capabilities strip -->
      <div class="promo-strip">
        <div class="promo-strip__text">
          <h3>We know design.</h3>
          <p>Our labs house a custom-built anechoic chamber (700 MHz – 18 GHz) for near-field and far-field antenna measurements, alongside industry-standard VNAs, spectrum analyzers, and GPU compute clusters.</p>
          <a href="#work" class="btn btn--primary">View Gallery</a>
        </div>
        <div class="promo-strip__img">
          <img src="/Media_1/pictures/Chamber_2023.jpg" alt="ARC Anechoic Chamber" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── TEAM ──────────────────────────────────────────────────────── -->
  <section class="section" id="team">
    <div class="container">
      <span class="section-eyebrow">The Group</span>
      <h2 class="section-title">Meet the Team</h2>

      <PeopleSection title="Faculty" people={faculty} cardSize="faculty" columns={1} />
      <hr class="divider" />
      <PeopleSection title="PhD Candidates" people={phd} columns={2} />
      <hr class="divider" />
      <PeopleSection title="MS Students" people={ms} columns={2} />
      <hr class="divider" />
      <PeopleSection title="Undergraduate Students" people={undergrad} columns={2} />

      <!-- Past Members collapsible -->
      <details class="past-group">
        <summary>Past Members</summary>
        <div class="past-group__body">
          <PeopleSection title="Past Co-Director" people={pastFaculty} cardSize="faculty" columns={1} />
          <hr class="divider" />
          <PeopleSection title="Past PhD Students" people={pastPhd} columns={2} />
          <hr class="divider" />
          <PeopleSection title="Past MS Students" people={pastMs} columns={2} />
          <hr class="divider" />
          <PeopleSection title="Past Undergraduate Students" people={pastUnder} columns={2} />
        </div>
      </details>
    </div>
  </section>

  <!-- ── SCHOLARSHIP ───────────────────────────────────────────────── -->
  <section class="section section--light" id="scholarship">
    <div class="container">
      <span class="section-eyebrow">Funding Opportunities</span>
      <h2 class="section-title">Viceroy Fellowship</h2>
      <div class="scholarship-grid">
        <div class="scholarship-info">
          <div class="scholarship-badge">$2,500 / semester + Paid Summer Internship</div>
          <p>The Viceroy Fellowship is a Colorado Virtual Center program led by UCCS and funded by the Griffiss Institute via the Under Secretary of Defense Research and Engineering.</p>
          <h4>Requirements</h4>
          <ul>
            <li>Current EE undergraduate at Colorado School of Mines with emphasis on antennas &amp; wireless</li>
            <li>Coursework in Electromagnetics, Antennas, Phased Arrays, Microwave Devices, RFID, or Computational EM</li>
            <li>Eligible for DoD security clearance</li>
            <li>Intent to pursue DoD or defense industry employment</li>
            <li>Participation in research and paid summer internship</li>
          </ul>
          <div class="deadline-list">
            <h4>Upcoming Deadlines</h4>
            <div class="deadline"><span>Fall 2026</span><strong>April 3, 2026</strong></div>
          </div>
          <p class="scholarship-contact">Contact: <a href="mailto:aelsherb@mines.edu">aelsherb@mines.edu</a></p>
        </div>
        <div class="scholarship-apply">
          <img src="/Media_1/pictures/viceroy.png" alt="Viceroy Fellowship Logo" class="scholarship-logo" />
          <h4>Before applying, prepare:</h4>
          <ul>
            <li>Educational and professional goals (PDF, ≤1 page)</li>
            <li>Response: significant DoD cybersecurity / EMS challenges (PDF, ≤1 page)</li>
            <li>Current transcript</li>
            <li>One recommendation letter</li>
          </ul>
          <p class="note">You must be signed in to your @mines.edu Google account to apply.</p>
          <a href="https://forms.gle/PWXXWCzT1SbKd4dL9" target="_blank" rel="noopener noreferrer" class="btn btn--primary">Apply Online →</a>
        </div>
      </div>
    </div>
  </section>

<!-- ── NEWS ─────────────────────────────────────────────────────── -->
<section class="section" id="news">
  <div class="container">
    <span class="section-eyebrow">Latest Updates</span>
    <h2 class="section-title">News</h2>

    <!-- Current year always visible -->
    <div class="news-list">
      {currentYearItems.map(item => <NewsItemComponent item={item} />)}
    </div>

    <!-- Archive: one collapsible per year -->
    <div class="news-archive">
      <h3 class="news-archive__heading">Archive</h3>
      {archiveYears.map(year => (
        <details class="past-group">
          <summary>{year}</summary>
          <div class="past-group__body news-list">
            {getNewsByYear(year).map(item => <NewsItemComponent item={item} />)}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

  <!-- ── GALLERY ───────────────────────────────────────────────────── -->
  <section class="section section--light" id="work">
    <div class="container">
      <span class="section-eyebrow">Our Work</span>
      <h2 class="section-title">Gallery</h2>
      <div style="text-align:center; margin-bottom: 2rem;">
        <a href="/Projects/Publications/publications.html" class="btn btn--primary" target="_blank">Publications →</a>
      </div>
      <div class="gallery-grid">
        <img src="/Media_1/research/frontpage/ant1.jpg" alt="CubeSat antenna" class="gallery-img" />
        <img src="/Media_1/research/frontpage/ant4.jpg" alt="Antenna pattern" class="gallery-img" />
        <img src="/Media_1/research/frontpage/rfid4.jpg" alt="RFID system" class="gallery-img" />
        <img src="/Media_1/research/frontpage/cem3.jpg" alt="FDTD simulation" class="gallery-img" />
        <img src="/Media_1/pictures/lab4.jpg" alt="Antenna test range" class="gallery-img" />
        <img src="/Media_1/pictures/aces_madison.JPG" alt="ACES Conference" class="gallery-img" />
        <img src="/Media_1/pictures/lab3.jpg" alt="ARC Lab" class="gallery-img" />
        <img src="/Media_1/pictures/aces_all.JPG" alt="ACES 2019 group" class="gallery-img" />
      </div>
    </div>
  </section>

  <!-- ── SOFTWARE ──────────────────────────────────────────────────── -->
  <section class="section" id="software">
    <div class="container">
      <span class="section-eyebrow">Open Source Tools</span>
      <h2 class="section-title">Software</h2>
      <p class="section-lead">Software packages developed by the ARC Lab, freely available for download and use.</p>
      <ul class="software-list">
        <li><a href="/Software/waveguide_cavity.html" class="software-link" target="_blank">The Waveguide and Cavity Package</a></li>
        <li><a href="/Software/2d_fdtd_vis.html" class="software-link" target="_blank">2D Finite Difference Time Domain Visualization</a></li>
        <li><a href="/Software/1d_fdtd_code.html" class="software-link" target="_blank">1D MATLAB Finite Difference Time Domain Code</a></li>
        <li><a href="/Software/gui_planewave.html" class="software-link" target="_blank">GUI for Plane Wave Scattering from a Conducting, Dielectric, or Chiral Sphere</a></li>
        <li><a href="/Software/gui_calc_reflection.html" class="software-link" target="_blank">GUI for Reflection &amp; Transmission Coefficients of a Layered Medium</a></li>
      </ul>
    </div>
  </section>

  <!-- ── CONTACT ───────────────────────────────────────────────────── -->
  <section class="section section--light" id="contact">
    <div class="container">
      <span class="section-eyebrow">Get In Touch</span>
      <h2 class="section-title">Contact</h2>
      <div class="contact-grid">
        <div class="contact-info">
          <p>📍 Brown Hall, 1610 Illinois St., Golden, Colorado 80401, USA</p>
          <p>🏢 Office: Brown Building 314C</p>
          <p>✉️ <a href="mailto:aelsherb@mines.edu">aelsherb@mines.edu</a></p>
        </div>
        <form class="contact-form" action="mailto:aelsherb@mines.edu" method="post" enctype="text/plain">
          <input name="Name" type="text" placeholder="Name" required class="form-input" />
          <input name="Email" type="email" placeholder="Email" required class="form-input" />
          <input name="Subject" type="text" placeholder="Subject" required class="form-input" />
          <textarea name="Message" placeholder="Message" rows="4" required class="form-input"></textarea>
          <button type="submit" class="btn btn--primary">Send Message →</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    background-image: url("/Media_1/pictures/lab4.jpg");
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: white;
  }

  @media (max-width: 768px) {
    .hero { background-attachment: scroll; min-height: 85svh; }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(27, 58, 107, 0.85) 0%, rgba(0,0,0,0.5) 100%);
  }

  .hero__inner {
    position: relative;
    padding-block: 6rem 3rem;
    max-width: 680px;
  }

  .hero .section-eyebrow { color: rgba(255,255,255,0.8); }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .hero__sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    max-width: 52ch;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .hero__cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn--outline-white {
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.6);
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn--outline-white:hover { background: rgba(255,255,255,0.15); }

  .hero__stats {
    position: relative;
    display: flex;
    background: rgba(27, 58, 107, 0.92);
    backdrop-filter: blur(8px);
    margin-top: auto;
  }

  .stat {
    flex: 1;
    text-align: center;
    padding: 1.25rem 0.5rem;
    border-right: 1px solid rgba(255,255,255,0.1);
  }
  .stat:last-child { border: none; }

  .stat__num {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    color: white;
    line-height: 1;
  }

  .stat__label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-top: 0.2rem;
  }

  /* ── SECTIONS ──────────────────────────────────────────────────── */
  .section { padding-block: var(--section-py); }
  .section--light { background: #f0ede7; }

  /* ── RESEARCH GRID ─────────────────────────────────────────────── */
  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .research-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: box-shadow 0.2s;
  }

  .research-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.07); }

  .research-card__icon { font-size: 2rem; margin-bottom: 0.75rem; }

  .research-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-navy);
  }

  .research-card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.6; }

  /* promo strip */
  .promo-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    background: var(--color-navy);
    border-radius: 12px;
    padding: 2.5rem;
    color: white;
  }

  .promo-strip h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .promo-strip p { color: rgba(255,255,255,0.8); margin-bottom: 1.5rem; line-height: 1.6; }

  .promo-strip__img img {
    border-radius: 8px;
    width: 100%;
    height: 280px;
    object-fit: cover;
  }

  @media (max-width: 680px) {
    .promo-strip { grid-template-columns: 1fr; }
    .promo-strip__img { order: -1; }
    .promo-strip__img img { height: 200px; }
  }

  /* ── NEWS ──────────────────────────────────────────────────────── */
  .news-list { display: flex; flex-direction: column; gap: 2rem; }

  .news-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .news-item:last-child { border: none; padding-bottom: 0; }

  .news-item__meta time {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding-top: 0.2rem;
  }

  .news-item__content {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .news-item__img {
    width: 140px;
    height: 100px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .news-item__content h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
    color: var(--color-navy);
  }

  .news-item__content p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.6; }

  @media (max-width: 600px) {
    .news-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .news-item__content { grid-template-columns: 1fr; }
    .news-item__img { width: 100%; height: 160px; }
  }

  /* ── GALLERY ───────────────────────────────────────────────────── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 6px;
    transition: opacity 0.2s;
  }

  .gallery-img:hover { opacity: 0.88; }

  @media (max-width: 700px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── SCHOLARSHIP ───────────────────────────────────────────────── */
  .scholarship-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 700px) {
    .scholarship-grid { grid-template-columns: 1fr; }
  }

  .scholarship-badge {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .scholarship-info h4,
  .scholarship-apply h4 {
    font-weight: 600;
    margin: 1rem 0 0.5rem;
    color: var(--color-navy);
  }

  .scholarship-info ul,
  .scholarship-apply ul {
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .deadline-list { margin-top: 1rem; }

  .deadline {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--color-border);
    font-size: 0.875rem;
  }

  .scholarship-contact { margin-top: 1rem; font-size: 0.875rem; color: var(--color-muted); }
  .scholarship-contact a { color: var(--color-link); }

  .scholarship-logo { max-width: 200px; margin-bottom: 1rem; }

  .note { font-size: 0.75rem; color: var(--color-muted); margin: 0.75rem 0; font-style: italic; }

  /* ── SOFTWARE ──────────────────────────────────────────────────── */
  .software-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; max-width: 700px; }

  .software-link {
    display: block;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-link);
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.15s, border-color 0.15s;
  }

  .software-link:hover {
    background: var(--color-accent-light);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ── CONTACT ───────────────────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 700px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  .contact-info {
    font-size: 0.925rem;
    line-height: 2;
    color: var(--color-muted);
  }
  .contact-info a { color: var(--color-link); }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .form-input {
    width: 100%;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    background: var(--color-surface);
    color: var(--color-text);
    transition: border-color 0.15s;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  textarea.form-input { resize: vertical; min-height: 100px; }
</style>
